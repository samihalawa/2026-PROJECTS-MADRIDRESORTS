{
  "$schema": "https://apify.com/schemas/v1/output.ide.json",
  "actorOutputSchemaVersion": 1,
  "title": "Facebook Marketplace Seller Manager output",
  "description": "Links and metadata for the latest management run outputs.",
  "properties": {
    "mode": {
      "type": "string",
      "title": "Mode"
    },
    "summary": {
      "type": "object",
      "title": "Summary"
    },
    "sampleDataUsed": {
      "type": "boolean",
      "title": "Sample data used"
    },
    "dataOrigin": {
      "type": "string",
      "title": "Data origin"
    },
    "resultCount": {
      "type": "number",
      "title": "Result count"
    },
    "authProofLevel": {
      "type": "string",
      "title": "Auth proof level"
    },
    "workflowReadiness": {
      "type": "string",
      "title": "Workflow readiness"
    },
    "defaultDatasetUrl": {
      "type": "string",
      "title": "Default dataset URL",
      "template": "{{links.apiDefaultDatasetUrl}}/items"
    }
  }
}
