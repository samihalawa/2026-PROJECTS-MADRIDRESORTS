{
  "$schema": "https://apify.com/schemas/v1/output.ide.json",
  "actorOutputSchemaVersion": 1,
  "title": "Facebook Marketplace Seller Manager output",
  "description": "Links to the latest management outputs for the actor run.",
  "properties": {
    "results": {
      "type": "string",
      "title": "Management results",
      "template": "{{links.apiDefaultDatasetUrl}}/items"
    },
    "outputRecord": {
      "type": "string",
      "title": "Run summary record",
      "template": "{{links.apiDefaultKeyValueStoreUrl}}/records/OUTPUT"
    }
  }
}
